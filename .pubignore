# Exclude large iOS xcframeworks from pub package (~206 MB total).
# They are downloaded automatically during the first build via the podspec script phase.
# macOS dylibs (~13 MB) are small enough to bundle and are needed for `flutter test`.
ios/TensorFlowLiteC.xcframework/
ios/TensorFlowLiteCCoreML.xcframework/
ios/TensorFlowLiteCMetal.xcframework/

# flutter_litert_flex is a separate package (3.3 GB of .o files + xcframeworks)
flutter_litert_flex/
litert_flex/

# Build artifacts
build/

# Old example subdirectories (leftover from tflite_flutter)
example/live_object_detection_ssd_mobilenet/
example/reinforcement_learning/
example/text_classification/

# Dev/CI files
.github/
makefile
melos.yaml
scripts/
flutter-tflite.code-workspace
ffigen_tensorflow_lite.yaml
